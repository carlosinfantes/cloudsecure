# CloudSecure Assessment Platform - Configuration
# Copy to .env and fill in your values: cp .env.example .env

# ─── AWS Configuration ──────────────────────────────────────
# AWS CLI profile to use (run 'aws configure list-profiles' to see available)
AWS_PROFILE=default

# AWS region for deployment
AWS_REGION=eu-west-1

# Environment name (dev | test | prod)
CLOUDSECURE_ENV=dev

# ─── Prowler Configuration ──────────────────────────────────
# Pre-built Prowler image on Docker Hub (pulled during deployment)
PROWLER_IMAGE=carlosinfantes/cloudsecure-prowler:latest

# Set to 'true' to skip Prowler (if Docker is not available)
SKIP_PROWLER=false
